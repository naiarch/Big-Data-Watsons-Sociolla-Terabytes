from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from webdriver_manager.chrome import ChromeDriverManager
from urllib.parse import quote
from datetime import datetime
import pandas as pd
import time
import os

# setup chrome
chrome_options = Options()
chrome_options.add_argument("--start-maximized")
chrome_options.add_argument(
    "user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
    "AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
)
driver = webdriver.Chrome(
    service=Service(ChromeDriverManager().install()),
    options=chrome_options
)

PRODUCT_SELECTOR = "//div[contains(@class,'productInfo')]"
SAVE_DIR = "watsons_data"
os.makedirs(SAVE_DIR, exist_ok=True)

def kategori_sudah_selesai(category):
    safe_name = category.replace(" ", "_").lower()
    return os.path.exists(f"{SAVE_DIR}/watsons_{safe_name}.csv")

def simpan_kategori(category, data):
    if not data:
        print(f"Tidak ada data untuk {category}")
        return
    safe_name = category.replace(" ", "_").lower()
    filename = f"{SAVE_DIR}/watsons_{safe_name}.csv"
    df = pd.DataFrame(data).drop_duplicates(subset=["nama_produk"])
    df.to_csv(filename, index=False)
    print(f"Saved: {filename} ({len(df)} produk)")

# list kategori
categories = [
    "Perawatan Kulit", "Facial", "Pembersih Wajah",
    "Pelembab Wajah", "Sunscreen", "Masker",
    "Makeup", "Hair Care", "Vitamin", "Parfum"
]

# loop kategori
for cat_idx, category in enumerate(categories):

    if kategori_sudah_selesai(category):
        print(f"SKIP {category} (sudah ada)")
        continue

    print(f"\n[{cat_idx+1}/{len(categories)}] SCRAPING: {category.upper()}")

    category_data = []
    nama_pertama_sebelumnya = None
    halaman_duplikat_count = 0

    for page in range(0, 200):

        url = (
            f"https://www.watsons.co.id/id/search?"
            f"text={quote(category)}"
            f"&useDefaultSearch=false"
            f"&brandRedirect=true"
            f"&currentPage={page}"
        )

        print(f"Halaman {page}")

        try:
            driver.get(url)
            WebDriverWait(driver, 30).until(
                EC.presence_of_element_located((By.CSS_SELECTOR, ".productInfo"))
            )
            time.sleep(2)
        except:
            print("Timeout, coba lagi...")
            # coba sekali lagi sebelum stop
            try:
                time.sleep(5)
                driver.refresh()
                WebDriverWait(driver, 30).until(
                    EC.presence_of_element_located((By.CSS_SELECTOR, ".productInfo"))
                )
            except:
                print("Tetap timeout, skip halaman ini")
                print("Data kemungkinan habis")
                print("Stop kategori ini")
                break
                

        # scroll sampai konten tidak bertambah
        last_height = driver.execute_script("return document.body.scrollHeight")
        no_change = 0
        for i in range(8):
            driver.execute_script("window.scrollTo(0, document.body.scrollHeight);")
            time.sleep(1)
            new_height = driver.execute_script("return document.body.scrollHeight")
            if new_height == last_height:
                no_change += 1
                if no_change >= 2:
                    break
            else:
                no_change = 0
            last_height = new_height

        products = driver.find_elements(By.XPATH, PRODUCT_SELECTOR)
        print(f"Produk ditemukan: {len(products)}")

        if len(products) == 0:
            print("Tidak ada produk, stop")
            break

        # cek apakah halaman ini duplikat
        try:
            nama_pertama = products[0].find_element(
                By.CSS_SELECTOR, ".productName"
            ).text.strip()
            print(f"Produk pertama: {nama_pertama}")

            if nama_pertama == nama_pertama_sebelumnya:
                halaman_duplikat_count += 1
                print(f"Halaman duplikat ({halaman_duplikat_count}x)")
                # stop hanya kalau duplikat 3x berturut-turut
                if halaman_duplikat_count >= 3:
                    print("Duplikat 3x berturut, data habis")
                    break
                page += 1
                continue
            else:
                halaman_duplikat_count = 0

            nama_pertama_sebelumnya = nama_pertama
        except:
            pass

        # extract data tiap produk
        for item in products:
            try:
                try:
                    nama = item.find_element(By.CSS_SELECTOR, ".productName").text.strip()
                except:
                    continue

                try:
                    harga = item.find_element(By.CSS_SELECTOR, ".formatted-value").text.strip()
                except:
                    continue

                try:
                    harga_original = item.find_element(
                        By.CSS_SELECTOR, ".productOriginalPrice del"
                    ).text.strip()
                except:
                    harga_original = None

                try:
                    harga_member = item.find_element(
                        By.CSS_SELECTOR, ".memberPrice span"
                    ).text.strip()
                except:
                    harga_member = None

                try:
                    diskon = item.find_element(By.CSS_SELECTOR, ".tab").text.strip()
                except:
                    diskon = None

                try:
                    stars = item.find_elements(
                        By.CSS_SELECTOR, ".reviewRatingStar .icon-star04"
                    )
                    rating = len(stars) if stars else None
                except:
                    rating = None

                try:
                    review_text = item.find_element(
                        By.CSS_SELECTOR, ".reviewCount"
                    ).text.strip()
                    jumlah_review = review_text.replace("(", "").replace(")", "").strip()
                    jumlah_review = int(jumlah_review) if jumlah_review.isdigit() else None
                except:
                    jumlah_review = None

                # jumlah terjual
                try:
                    terjual_text = item.find_element(
                        By.CSS_SELECTOR, ".social-proof"
                    ).text.strip()
                    jumlah_terjual = (
                        terjual_text
                        .replace("Terjual", "")
                        .replace("+", "")
                        .strip()
                    )
                    jumlah_terjual = jumlah_terjual if jumlah_terjual else None
                except:
                    jumlah_terjual = None

                try:
                    link = item.find_element(By.CSS_SELECTOR, "a").get_attribute("href")
                except:
                    link = None

                try:
                    url_gambar = item.find_element(
                        By.CSS_SELECTOR, "img"
                    ).get_attribute("src")
                except:
                    url_gambar = None

                if not nama or not harga:
                    continue

                category_data.append({
                    "toko": "Watsons",
                    "kategori": category,
                    "nama_produk": nama,
                    "harga": harga,
                    "harga_original": harga_original,
                    "harga_member": harga_member,
                    "diskon": diskon,
                    "rating": rating,
                    "jumlah_review": jumlah_review,
                    "jumlah_terjual": jumlah_terjual,
                    "lokasi": "Indonesia",
                    "brand": nama.split()[0],
                    "url_produk": link,
                    "url_gambar": url_gambar,
                    "tanggal_scraping": datetime.now().strftime("%Y-%m-%d"),
                    "halaman": page
                })

            except:
                continue

        print(f"Total terkumpul: {len(category_data)}")

    simpan_kategori(category, category_data)
    time.sleep(5)

# gabung semua csv jadi satu file
print("\nMenggabungkan semua file...")
all_files = [f"{SAVE_DIR}/{f}" for f in os.listdir(SAVE_DIR) if f.endswith(".csv")]

if all_files:
    df_all = pd.concat([pd.read_csv(f) for f in all_files], ignore_index=True)
    df_all = df_all.drop_duplicates(subset=["nama_produk"])

    for col in ["harga", "harga_original", "harga_member"]:
        df_all[col] = (
            df_all[col].astype(str)
            .str.replace("Rp", "", regex=False)
            .str.replace(".", "", regex=False)
            .str.replace(",", "", regex=False)
            .str.strip()
        )

    df_all["diskon"] = (
        df_all["diskon"].astype(str)
        .str.replace("%", "")
        .str.replace("–", "")
        .str.strip()
    )

    for col in ["harga", "harga_original", "harga_member", "diskon", "rating", "jumlah_review"]:
        df_all[col] = pd.to_numeric(df_all[col], errors="coerce")

    df_all = df_all.reset_index(drop=True)
    df_all.to_csv("watsons_big_dataset.csv", index=False)
    print(f"Selesai! Total: {len(df_all)} produk")
    print(f"File: watsons_big_dataset.csv")

driver.quit()